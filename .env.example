# ── frontend-next environment ─────────────────────────────────────────────
# Client-exposed vars MUST be prefixed NEXT_PUBLIC_ (D6). Everything else is
# server-only. Copy to .env.local and fill real values for local dev.

# Backend API base. Same-origin in prod via nginx → defaults to "/api" (C10).
# Do NOT hardcode https://jobmesh.in/api or http://localhost:4000 anywhere in src.
NEXT_PUBLIC_API_BASE_URL=/api

# Canonical site origin, used for absolute URLs in sitemap/robots/metadata.
# Local dev: http://localhost:3001 (Next runs on 3001, Express backend on 3000).
NEXT_PUBLIC_SITE_URL=https://jobmesh.in

# Google OAuth client id (seeker login). Was VITE_GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# logo.dev token for company logos. Was VITE_LOGODEV_TOKEN.
NEXT_PUBLIC_LOGODEV_TOKEN=

# Server-only: where Next dev rewrites /api/* to (the Express dev port). Not
# exposed to the browser. In prod this is unused (nginx serves same-origin).
DEV_API_PROXY_ORIGIN=http://localhost:3000

# Server-only: origin the server-fetch helper calls the backend on during SSR.
# Server code has no implicit same-origin, so it needs a concrete host. In prod
# point this at the internal backend (e.g. http://127.0.0.1:3000). Falls back to
# DEV_API_PROXY_ORIGIN, then http://localhost:3000, when unset.
SERVER_API_ORIGIN=http://localhost:3000
